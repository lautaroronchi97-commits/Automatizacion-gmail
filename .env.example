# Copiá este archivo como .env y completá los valores.

# Ruta al archivo de credenciales OAuth descargado de Google Cloud Console.
GMAIL_CREDENTIALS_FILE=credentials.json

# Ruta donde se guarda/lee el token de acceso (se crea solo en el primer login).
GMAIL_TOKEN_FILE=token.json

# Cantidad máxima de correos a procesar por corrida (seguridad). 0 = sin límite.
MAX_MESSAGES=0
